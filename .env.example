# EN: Copy to `.env` to override defaults. All values are optional — the framework runs
#     out of the box against public demo sites with no .env file at all.
# TR: Varsayılanları ezmek için `.env` olarak kopyala. Tüm değerler isteğe bağlıdır — framework
#     hiç .env dosyası olmadan da public demo sitelerine karşı kutudan çıktığı gibi çalışır.

# EN: UI system under test (Playwright baseURL). / TR: Test edilen arayüz (Playwright baseURL).
BASE_URL=https://www.saucedemo.com

# EN: API system under test. / TR: Test edilen API.
API_BASE_URL=https://jsonplaceholder.typicode.com

# EN: Named environment to load from utils/configReader.ts. / TR: utils/configReader.ts'ten yüklenecek isimli ortam.
TEST_ENV=demo

# EN: Force a specific saucedemo account (else per-shard pool is used).
# TR: Belirli bir saucedemo hesabını zorla (aksi halde shard-başına havuz kullanılır).
# PW_USER=standard_user

# EN: Email reporting (optional). The email script is skipped unless all are set.
# TR: E-posta raporlama (isteğe bağlı). Hepsi set edilmezse e-posta scripti atlanır.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-user
# SMTP_PASS=your-pass
# EMAIL_TO=recipient@example.com
# EMAIL_FROM=sender@example.com
