# EN: Files downloaded during tests — the folder is kept (.gitkeep), its contents are not.
# TR: Testler sırasında indirilen dosyalar — klasör korunur (.gitkeep), içeriği commit'lenmez.
downloads/*
!downloads/.gitkeep

